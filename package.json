{
  "name": "solo-developing-portfolio",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Professional portfolio website for Solo Developing - Full-stack developer specializing in React, Node.js, and AI integration",
  "author": "Solo Developing",
  "homepage": "https://solodeveloping.com",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "postbuild": "react-snap",
    "preview": "vite preview",
    "deploy": "vite build --mode production && react-snap && node deploy.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-toast": "^1.1.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "framer-motion": "^12.35.2",
    "gsap": "^3.14.2",
    "i18next": "^25.8.17",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "lenis": "^1.3.17",
    "lucide-react": "^0.577.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^16.5.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.5.3",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-pretty-code": "^0.14.1",
    "rehype-raw": "^7.0.0",
    "shiki": "^3.21.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^1.14.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "reactSnap": {
    "source": "dist",
    "puppeteerExecutablePath": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "include": [
      "/",
      "/404",
      "/about",
      "/articles",
      "/fullstack",
      "/mobile-developer",
      "/ai-developer",
      "/fr/",
      "/fr/about",
      "/fr/articles",
      "/fr/fullstack",
      "/fr/mobile-developer",
      "/fr/ai-developer",
      "/articles/first-flutter-package-pwa-installer",
      "/articles/flutter-firebase-lazy-loading",
      "/articles/flutter-pwa-guide",
      "/articles/why-i-dont-build-saas-around-ai-api-keys"
    ],
    "waitFor": 2000,
    "skipThirdPartyRequests": true
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "dotenv": "^16.5.0",
    "eslint": "^10.0.3",
    "ftp-deploy": "^2.4.7",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.31",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.3.3",
    "terser": "^5.39.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
