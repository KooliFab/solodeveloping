# Google Analytics (optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Contact Form Backend Endpoint (no secret in frontend)
VITE_CONTACT_FORM_ENDPOINT=https://your-api-domain.com/contact

# Slack Incoming Webhook — intentional direct delivery, used when no backend proxy is configured.
# The URL is never hardcoded in source: it is injected at build/runtime via this env variable only.
# VITE_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Add other environment variables below
