# Firebase configuration
# Replace these with your Firebase project details
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# App URL Configuration
VITE_APP_URL=https://your-app-domain.web.app/

# Slack Webhook Configuration
# Get your webhook URL from: https://api.slack.com/messaging/webhooks
VITE_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Add other environment variables below 